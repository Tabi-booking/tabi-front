# Copia este archivo a .env.local para desarrollo.
# En Vercel: Project Settings → Environment Variables (Production, Preview, Development).
#
# Checklist Vercel:
# 1. Importar el repo en https://vercel.com/new
# 2. Framework: Next.js (auto). Package manager: pnpm (auto desde lockfile).
# 3. Definir las variables NEXT_PUBLIC_* abajo en Production y Preview.
# 4. En el backend API, permitir CORS desde tu dominio *.vercel.app y dominio custom.
# 5. Deploy. La ruta /api/media corre como serverless en Vercel.

# API backend (requerido en producción; sin esto el front apunta a localhost)
# Ejemplo: https://api.tabiapp.tech
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase Storage (imágenes del restaurante)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=restaurants

# URL del portal de registro de restaurantes (opcional)
NEXT_PUBLIC_REGISTRO_URL=https://registro.tabiapp.tech/registro
